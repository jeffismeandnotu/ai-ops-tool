{
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/gmail/watch?secret=${CRON_SECRET}",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/reminders?secret=${CRON_SECRET}",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/purge-intent?secret=${CRON_SECRET}",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/campaigns?action=run-due&secret=${CRON_SECRET}",
      "schedule": "*/5 * * * *"
    }
  ]
}
